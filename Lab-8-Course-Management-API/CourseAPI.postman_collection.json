{
  "info": {
    "name": "Course Management API",
    "description": "Lab 8 — Udemy-Style Course API (Express + MongoDB)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",    "value": "http://localhost:5000/api/courses" },
    { "key": "course_id_1", "value": "" },
    { "key": "course_id_2", "value": "" },
    { "key": "course_id_3", "value": "" },
    { "key": "course_id_4", "value": "" },
    { "key": "course_id_5", "value": "" }
  ],
  "item": [
    {
      "name": "── CREATE COURSES ──",
      "item": [
        {
          "name": "CREATE Course 1 — Web Development",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}", "host": ["{{base_url}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Full Stack Web Development\",\n  \"description\": \"Learn HTML, CSS, JavaScript, Node.js and MongoDB from scratch to build real-world applications.\",\n  \"instructor\": \"Ahmed Hassan\",\n  \"price\": 49.99,\n  \"category\": \"Web Development\",\n  \"enrolledStudents\": 3200\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Has _id', () => pm.expect(res).to.have.property('_id'));",
                  "pm.test('Title matches', () => pm.expect(res.title).to.eql('Full Stack Web Development'));",
                  "pm.collectionVariables.set('course_id_1', res._id);",
                  "console.log('course_id_1:', res._id);"
                ]
              }
            }
          ]
        },
        {
