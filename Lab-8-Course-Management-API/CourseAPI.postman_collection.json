        {
          "name": "CREATE Course 5 — React Native",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}", "host": ["{{base_url}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"React Native Mobile Development\",\n  \"description\": \"Build cross-platform iOS and Android apps using React Native, Expo and Firebase from zero to deployment.\",\n  \"instructor\": \"Layla Mostafa\",\n  \"price\": 44.99,\n  \"category\": \"Mobile Development\",\n  \"enrolledStudents\": 0\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Has _id', () => pm.expect(res).to.have.property('_id'));",
                  "pm.test('Title matches', () => pm.expect(res.title).to.eql('React Native Mobile Development'));",
                  "pm.test('enrolledStudents defaults to 0', () => pm.expect(res.enrolledStudents).to.eql(0));",
