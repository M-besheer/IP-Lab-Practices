    },
    {
      "name": "── READ OPERATIONS ──",
      "item": [
        {
          "name": "READ ALL Courses",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}", "host": ["{{base_url}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Returns an array', () => pm.expect(res).to.be.an('array'));",
                  "pm.test('At least 5 courses exist', () => pm.expect(res.length).to.be.at.least(5));",
                  "pm.test('Each course has required fields', () => {",
                  "    res.forEach(course => {",
                  "        pm.expect(course).to.have.property('title');",
                  "        pm.expect(course).to.have.property('instructor');",
                  "        pm.expect(course).to.have.property('price');",
                  "        pm.expect(course).to.have.property('category');",
                  "        pm.expect(course).to.have.property('enrolledStudents');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "READ ONE Course (Course 1)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/{{course_id_1}}", "host": ["{{base_url}}/{{course_id_1}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Correct course returned', () => pm.expect(res._id).to.eql(pm.collectionVariables.get('course_id_1')));",
                  "pm.test('Has all fields', () => {",
                  "    pm.expect(res).to.have.all.keys('_id','title','description','instructor','price','category','enrolledStudents','__v');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "── UPDATE OPERATION ──",
      "item": [
        {
          "name": "UPDATE Course 3 — Lower Price & More Students",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/{{course_id_3}}", "host": ["{{base_url}}/{{course_id_3}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 24.99,\n  \"enrolledStudents\": 3500\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Success message returned', () => pm.expect(res.message).to.eql('Course updated successfully'));"
                ]
              }
            }
          ]
        },
        {
          "name": "VERIFY Update on Course 3",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/{{course_id_3}}", "host": ["{{base_url}}/{{course_id_3}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Price updated to 24.99', () => pm.expect(res.price).to.eql(24.99));",
                  "pm.test('enrolledStudents updated to 3500', () => pm.expect(res.enrolledStudents).to.eql(3500));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "── DELETE OPERATION ──",
      "item": [
        {
          "name": "DELETE Course 5 — React Native",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/{{course_id_5}}", "host": ["{{base_url}}/{{course_id_5}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Success message returned', () => pm.expect(res.message).to.eql('Course deleted successfully'));"
                ]
              }
            }
          ]
        },
        {
          "name": "VERIFY Delete — Should Return 404",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/{{course_id_5}}", "host": ["{{base_url}}/{{course_id_5}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status 404 Not Found', () => pm.response.to.have.status(404));",
                  "pm.test('Not found message returned', () => pm.expect(res.message).to.eql('Course not found'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
